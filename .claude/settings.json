{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.py) (cd \"$CLAUDE_PROJECT_DIR\" && uv run ruff format \"$f\" && uv run ruff check --fix \"$f\");; esac; } 2>/dev/null || true",
            "statusMessage": "ruff format on .py edit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run pre-commit run --all-files",
            "statusMessage": "pre-commit run --all-files",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run pytest tests/",
            "statusMessage": "pytest tests/ (repo standards)",
            "timeout": 180
          },
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && bash scripts/local-ci/run-subproject-tests.sh",
            "statusMessage": "pytest per uv workspace member",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
